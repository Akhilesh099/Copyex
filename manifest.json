{
  "manifest_version": 3,
  "name": "Universal Stealth Architect v3",
  "version": "3.1",
  "description": "Architect-level stealth suite: Zero-latency event hijacking, resolution spoofing, and network blackholing.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stealth Control"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "file://*/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
